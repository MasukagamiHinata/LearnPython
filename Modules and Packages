#パッケージとは、複数のモジュールを整理するための仕組み
#パッケージの役割
#名前空間の提供: 
#   パッケージは、モジュールやサブパッケージの論理的な階層構造を形成し、名前の衝突を防ぐ。
#   たとえば、foo.barというモジュールは、fooパッケージ内のbarモジュールであることを明確に示す。
#モジュールの整理: 
#   関連するモジュールをひとつのディレクトリにまとめることで、プロジェクトの構造を整理し、管理しやすくする。
#インポートの管理: 
#   __init__.pyファイルは、パッケージがインポートされたときに実行され、パッケージレベルの初期化処理を行ったり、
#   パッケージの公開APIを定義したりするのに使われる。

#fooというディレクトリに__init__.pyファイルとbar.pyモジュールがある場合、barモジュールをインポートする方法は主に2つ
import foo.bar

from foo import bar

#また、特定の関数やクラスだけをインポートすることも可能。
from foo.bar import MyClass


#__init__.pyファイルでは、__all__変数をオーバーライドすることで、パッケージがAPIとしてエクスポートするモジュールを決定
__init__.py
__all__ = ["bar"]


#Exercise
#reモジュール内のすべての関数の中から、findという単語を含むものをアルファベット順に並べ替えてリストとして出力
import re
help(re)
dir(re)
#このモジュールは正規表現マッチング操作を提供する
find_members = []
for member in dir(re):
    if "find" in member:
        find_members.append(member)

print(sorted(find_members))
