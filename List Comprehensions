#Python

#特定の文章内の各単語の長さを指定する整数のリストを作成する
#ただし、単語が「the」でない場合に限る
sentence = "the quick brown fox jumps over the lazy dog"
words = sentence.split()
word_length = []
for word in words:
    if word != "the":
        word_length.append(len(word))
print(words)
print(word_length)

#リスト内包表記を用いると簡潔に書ける
#でも複雑な文だとむしろわかりにくく、使いにくくなりそう
#また大量のデータに対して行うとメモリを一度にたくさん使う(リストなので)から少し注意が必要なのかも？
#メモリを気にする場合はジェネレータが有用か
sentence = "the quick brown fox jumps over the lazy dog"
words = sentence.split()
word_length = [len(word) for word in words if word != "the"]
print(word_length)

