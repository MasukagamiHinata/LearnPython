#リスト内包表記を使用して、リスト「numbers」から「newlist」という新しいリストを作成し、
#その中には元のリストからの正の数のみを整数として含めてください。
numbers = [34.6, -203.4, 44.9, 68.3, -12.2, 44.6, 12.7, 0.9, -0.1]
